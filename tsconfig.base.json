{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@coreforge/types": ["packages/types/src"],
      "@coreforge/sdk": ["packages/sdk/src"],
      "@coreforge/ui": ["packages/ui/src"],
      "@coreforge/config": ["packages/config/src"]
    }
  }
}
